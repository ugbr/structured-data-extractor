# ---- Secrets ----
.env
.env.*
!.env.example

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---- Virtual env / uv ----
.venv/
venv/

# ---- Data & outputs ----
