data/documents/*
!data/documents/.gitkeep
# Generated extraction runs, tables, and traces.
results/*
!results/.gitkeep

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/

# ---- Local learning materials (not part of the public repo) ----
